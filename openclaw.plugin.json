{
  "id": "multi-agent-turn-arbiter",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean" },
      "enabledChannels": {
        "type": "array",
        "items": { "type": "string" },
        "default": []
      },
      "activeRunLeaseMs": {
        "type": "number",
        "default": 180000,
        "minimum": 1000
      },
      "postSendGraceMs": {
        "type": "number",
        "default": 15000,
        "minimum": 1000
      },
      "stateIdleMs": {
        "type": "number",
        "default": 300000,
        "minimum": 1000
      },
      "maxBacklogTurns": {
        "type": "number",
        "default": 6,
        "minimum": -1
      },
      "maxPromptChars": {
        "type": "number",
        "default": 30000,
        "minimum": -1
      },
      "failOpen": {
        "type": "boolean",
        "default": true
      },
      "debug": {
        "type": "boolean",
        "default": false
      }
    }
  }
}
