{
  "id": "multi-agent-turn-arbiter",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean" },
      "enabledChannels": {
        "type": "array",
        "items": { "type": "string" },
        "default": []
      },
      "leaseMs": {
        "type": "number",
        "default": 30000,
        "minimum": 1000
      },
      "activeRunLeaseMs": {
        "type": "number",
        "default": 300000,
        "minimum": 1000
      },
      "settleMs": {
        "type": "number",
        "default": 10000,
        "minimum": 250
      },
      "botReopenCooldownMs": {
        "type": "number",
        "default": 30000,
        "minimum": 0
      },
      "epochIdleMs": {
        "type": "number",
        "default": 300000,
        "minimum": 60000
      },
      "maxBotHops": {
        "type": "number",
        "default": 16,
        "minimum": -1
      },
      "maxBacklogTurns": {
        "type": "number",
        "default": 6,
        "minimum": -1
      },
      "maxPromptChars": {
        "type": "number",
        "default": 30000,
        "minimum": -1
      },
      "failOpen": {
        "type": "boolean",
        "default": true
      },
      "debug": {
        "type": "boolean",
        "default": false
      }
    }
  }
}
